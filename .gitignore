# =============================================================================
# AION OS - Git Ignore Configuration
# =============================================================================
# This file protects sensitive data from accidental commits.
# Court documents and pattern data MUST stay local.
# =============================================================================

# -----------------------------------------------------------------------------
# CRITICAL: Proprietary Knowledge Base (NEVER COMMIT)
# -----------------------------------------------------------------------------
# These files contain court documents, case details, and extracted patterns.
# Committing these would expose client-confidential litigation data.

aionos/knowledge/legal_patterns.json
aionos/knowledge/court_documents.json
aionos/knowledge/*.json
!aionos/knowledge/README.md

# -----------------------------------------------------------------------------
# Configuration Files with Credentials (NEVER COMMIT)
# -----------------------------------------------------------------------------
# These contain API tokens and client credentials.
# Only .example.json files should be committed.

.env
.env.local
.env.*.local
config/**/*.json
config/*.json
config/webhook_auth.json
config/watchdog.json
!config/*.example.json

# -----------------------------------------------------------------------------
# Logs and Runtime Data
# -----------------------------------------------------------------------------
logs/
*.log
aion_node.log
aionos/logs/

# -----------------------------------------------------------------------------
# Reports (May Contain Client Data)
# -----------------------------------------------------------------------------
reports/*.pdf
reports/*.json

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv/

# -----------------------------------------------------------------------------
# IDE and Editor
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# -----------------------------------------------------------------------------
# OS Generated
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# -----------------------------------------------------------------------------
# Testing and Coverage
# -----------------------------------------------------------------------------
.coverage
htmlcov/
.tox/
.pytest_cache/
.mypy_cache/

# -----------------------------------------------------------------------------
# Temporary Files
# -----------------------------------------------------------------------------
*.tmp
*.temp
*.bak

